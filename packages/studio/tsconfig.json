{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@sap-geometry/core": ["../core/src/index.ts"],
      "@sap-geometry/viewer/*": ["../viewer/src/*"]
    }
  },
  "include": ["src"]
}
